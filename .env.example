# Main Next.js app — `npm run dev` uses port 3000 by default.

NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_OPEN_API_KEY_FOR_CHAT=
NEXT_PUBLIC_OPEN_API_FOR_CHAT=
NEXT_PUBLIC_APP_FE_URL=http://localhost:3000
NEXT_PUBLIC_ENVIRONMENT=dev

NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3000/google/callback

NEXT_PUBLIC_MICROSOFT_CLIENT_ID=
# Must match Azure “Web” redirect URI exactly (e.g. http://localhost:3000/oauthcallback).
NEXT_PUBLIC_MICROSOFT_OAUTH_REDIRECT_URL=http://localhost:3000/oauthcallback
